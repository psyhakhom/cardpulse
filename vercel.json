{
  "rewrites": [
    { "source": "/api/image-proxy", "destination": "/api/image-proxy.js" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/seed-prices",
      "schedule": "0 2 * * *"
    }
  ]
}
